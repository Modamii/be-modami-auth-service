{
  "token_hmac_secret_key": "${CENTRIFUGO_HMAC_SECRET}",
  "api_key": "${CENTRIFUGO_API_KEY}",
  "admin": true,
  "admin_password": "${CENTRIFUGO_ADMIN_PASSWORD}",
  "admin_secret": "${CENTRIFUGO_ADMIN_SECRET}",
  "allowed_origins": ["http://localhost:3000", "http://localhost:5173"],
  "client_channel_limit": 128,
  "log_level": "debug",

  "proxies": [
    {
      "name": "chat-subscribe",
      "endpoint": "http://host.docker.internal:8090/centrifugo/proxy/subscribe",
      "timeout": "3s"
    },
    {
      "name": "chat-publish",
      "endpoint": "http://host.docker.internal:8090/centrifugo/proxy/publish",
      "timeout": "3s"
    }
  ],

  "namespaces": [
    {
      "name": "chat",
      "presence": true,
      "join_leave": true,
      "history_size": 100,
      "history_ttl": "24h",
      "force_recovery": true,
      "subscribe_proxy_enabled": true,
      "subscribe_proxy_name": "chat-subscribe",
      "publish_proxy_enabled": true,
      "publish_proxy_name": "chat-publish"
    }
  ]
}
